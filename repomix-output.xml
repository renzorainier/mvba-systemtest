export default function AddStudentsModal({ open, onClose }) {
  const [formData, setFormData] = useState({
    firstName: '',
    lastName: '',
    middleName: '',
    gender: '',
    dateOfBirth: '',
    address: '',
    admissionDate: '',
    studentId: '',
  })
  const [loading, setLoading] = useState(false)
